# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual credentials.

# Absolute path to your iOS project root (required by Docker Compose)
WORKSPACE_PATH=/path/to/your/ios/project

# Neo4j password (change this for production!)
NEO4J_PASSWORD=codegraph123

# (Optional) DashScope API key for hybrid search (BM25 + vector embedding)
# Get your key at: https://dashscope.console.aliyun.com/
# If not set, search will fall back to BM25-only mode.
# DASHSCOPE_API_KEY=sk-your-dashscope-api-key
